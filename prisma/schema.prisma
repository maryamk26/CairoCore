generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider          = "postgresql"
  url               = env("DATABASE_URL")
  shadowDatabaseUrl = env("SHADOW_DATABASE_URL")
}

model User {
  id        String   @id
  email     String   @unique
  createdAt DateTime @default(now())

  places Place[]

  @@map("users")
}

model Place {
  id            String   @id @default(uuid())
  name          String
  description   String?  @db.Text
  category      String?
  latitude      Float
  longitude     Float
  address       String?
  openingHours  String?
  entranceFee   Float?
  cameraFee     Float?
  vibe          String?
  bestVisitTime String?
  createdBy     String?
  createdAt     DateTime @default(now())

  user User? @relation(fields: [createdBy], references: [id], onDelete: SetNull)

  @@map("places")
}
